{
  "expo": {
    "name": "FridgeWise",
    "slug": "fridgewise",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logowithtext.jpg",
    "notification": {
      "icon": "./assets/images/notification-fridge-icon.png",
      "color": "#15803D"
    },
    "scheme": "fridgewise",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses the camera to scan barcodes on food products."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logowithtext.jpg",
        "backgroundColor": "#ffffff"
      },
      "permissions": ["CAMERA"],
      "package": "com.aseef217.fridgewise"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow FridgeWise to access your camera to scan barcodes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
